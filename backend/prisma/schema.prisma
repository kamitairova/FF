generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  COMPANY
}

enum VacancyStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // COMPANY вакансии
  vacancies Vacancy[] @relation("CompanyVacancies")
}

model Vacancy {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  salaryFrom  Int?
  salaryTo    Int?
  city        String?
  status      VacancyStatus @default(PENDING)

  companyId   Int
  company     User          @relation("CompanyVacancies", fields: [companyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}