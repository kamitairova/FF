generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  COMPANY
  ADMIN
}

enum VacancyStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum WorkMode {
  REMOTE
  ONSITE
  HYBRID
}

enum ExperienceLevel {
  INTERN
  JUNIOR
  MIDDLE
  SENIOR
  LEAD
}

enum ResumeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  SUBMITTED
  REVIEWED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum NotificationType {
  NEW_MESSAGE
  APPLICATION_STATUS_CHANGED
  VACANCY_MODERATED
  RESUME_MODERATED
  INTERVIEW_PROPOSED
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  role       Role     @default(USER)
  isDisabled Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companyProfile CompanyProfile?
  seekerProfile  JobSeekerProfile?

  sentMessages  Message[]      @relation("MessageSender")
  notifications Notification[]

  @@index([role])
  @@index([isDisabled])
}

model CompanyProfile {
  id                      Int      @id @default(autoincrement())
  userId                  Int      @unique
  companyName             String   @default("")
  companyLogoUrl          String?
  companyShortDescription String?
  companyDescription      String?
  companyWebsite          String?
  companyPhone            String?
  companyCity             String?
  companyCountry          String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vacancies  Vacancy[]
  photos     CompanyPhoto[]
  threads    Thread[]

  @@index([companyName])
  @@index([companyCity])
  @@index([companyCountry])
}

model CompanyPhoto {
  id               Int      @id @default(autoincrement())
  companyProfileId Int
  imageUrl         String
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  companyProfile CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)

  @@index([companyProfileId])
}

model Vacancy {
  id              Int             @id @default(autoincrement())
  title           String
  description     String
  salaryFrom      Int?
  salaryTo        Int?
  city            String?
  category        String?
  employmentType  EmploymentType?
  workMode        WorkMode?
  experienceLevel ExperienceLevel?
  requiredSkills  String[]        @default([])
  status          VacancyStatus   @default(PENDING)
  wasPublishedBefore Boolean      @default(false)

  companyProfileId Int
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)

  applications Application[]
  savedBy      SavedJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyProfileId])
  @@index([status])
  @@index([createdAt])
  @@index([category])
  @@index([city])
  @@index([employmentType])
  @@index([workMode])
  @@index([experienceLevel])
}

model JobSeekerProfile {
  id              Int              @id @default(autoincrement())
  userId          Int              @unique
  firstName       String
  lastName        String?
  location        String?
  headline        String?
  experienceLevel ExperienceLevel?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos       SeekerPhoto[]
  resumes      Resume[]
  applications Application[]
  savedJobs    SavedJob[]
  threads      Thread[]

  @@index([firstName])
  @@index([lastName])
  @@index([location])
  @@index([experienceLevel])
}

model SeekerPhoto {
  id              Int      @id @default(autoincrement())
  seekerProfileId Int
  fileName        String
  mimeType        String
  storagePath     String
  sizeBytes       Int
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  seekerProfile JobSeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId])
}

model Resume {
  id                Int              @id @default(autoincrement())
  seekerProfileId   Int
  title             String
  desiredPosition   String?
  salaryExpectation Int?
  experienceLevel   ExperienceLevel?
  skills            String[]         @default([])
  isPublic          Boolean          @default(true)
  status            ResumeStatus     @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  seekerProfile JobSeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)
  resumeFile    ResumeFile?

  @@index([seekerProfileId])
  @@index([status])
  @@index([isPublic])
  @@index([updatedAt])
  @@index([desiredPosition])
  @@index([experienceLevel])
}

model ResumeFile {
  id          Int      @id @default(autoincrement())
  resumeId    Int      @unique
  fileName    String
  mimeType    String
  storagePath String
  sizeBytes   Int
  uploadedAt  DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Application {
  id              Int               @id @default(autoincrement())
  vacancyId       Int
  seekerProfileId Int
  status          ApplicationStatus @default(SUBMITTED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  vacancy       Vacancy          @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  seekerProfile JobSeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@unique([vacancyId, seekerProfileId])
  @@index([vacancyId])
  @@index([seekerProfileId])
  @@index([status])
}

model SavedJob {
  id              Int      @id @default(autoincrement())
  vacancyId       Int
  seekerProfileId Int
  createdAt       DateTime @default(now())

  vacancy       Vacancy          @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  seekerProfile JobSeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@unique([vacancyId, seekerProfileId])
  @@index([vacancyId])
  @@index([seekerProfileId])
}

model Thread {
  id               Int      @id @default(autoincrement())
  seekerProfileId  Int
  companyProfileId Int
  createdAt        DateTime @default(now())

  seekerProfile  JobSeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)
  companyProfile CompanyProfile   @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([seekerProfileId, companyProfileId])
  @@index([seekerProfileId])
  @@index([companyProfileId])
}

model Message {
  id           Int      @id @default(autoincrement())
  threadId     Int
  senderUserId Int
  body         String
  createdAt    DateTime @default(now())

  thread     Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUser User   @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderUserId])
  @@index([createdAt])
}

model Notification {
  id              Int              @id @default(autoincrement())
  recipientUserId Int
  type            NotificationType
  payloadJson     Json?
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())

  recipient User @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId])
  @@index([isRead])
  @@index([createdAt])
}